<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<title>Daily AI Insights · {{ date }}</title>
</head>
<body style="margin:0;padding:0;background:#F8F9FA;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI','PingFang TC','Microsoft JhengHei',sans-serif;color:#1A2B3C;">
<div style="max-width:680px;margin:0 auto;padding:24px 16px;">

  <!-- Header -->
  <div style="background:#1A2B3C;color:#fff;padding:24px;border-radius:12px;">
    <div style="font-size:13px;letter-spacing:2px;opacity:0.7;">DAILY AI INSIGHTS · CAPTAIN BALUNG</div>
    <h1 style="margin:8px 0 0;font-size:24px;font-weight:600;">{{ date }} 產業情報</h1>
  </div>

  <!-- Dashboard -->
  {% if dashboard %}
  <div style="margin-top:20px;background:#fff;padding:16px 20px;border-radius:12px;border-left:4px solid #2A9D8F;">
    <div style="font-size:13px;color:#666;margin-bottom:8px;">📊 今日看板</div>
    <table style="width:100%;font-size:14px;">
      <tr>
        {% for ticker, val in dashboard.items() %}
        <td style="padding:4px 8px;">
          <strong>{{ ticker }}</strong>
          <span style="color:{% if '+' in val %}#2A9D8F{% elif '-' in val %}#E63946{% else %}#888{% endif %};">{{ val }}</span>
        </td>
        {% endfor %}
      </tr>
    </table>
  </div>
  {% endif %}

  <!-- Sections -->
  {% for section in sections %}
  <div style="margin-top:24px;">
    <h2 style="font-size:18px;border-bottom:2px solid #1A2B3C;padding-bottom:6px;">{{ section.category_display }}</h2>

    {% if section['items'] %}
      {% for item in section['items'] %}
      <details style="margin:12px 0;background:#fff;padding:14px 18px;border-radius:10px;{% if item.priority == 'high' %}border-left:4px solid #E63946;{% else %}border-left:4px solid #1A2B3C;{% endif %}">
        <summary style="cursor:pointer;font-weight:600;font-size:15px;list-style:none;">
          {% if item.priority == 'high' %}<span style="background:#E63946;color:#fff;font-size:11px;padding:2px 6px;border-radius:4px;margin-right:6px;">重點</span>{% endif %}
          {{ item.title }}
        </summary>
        <div style="margin-top:10px;font-size:14px;line-height:1.6;color:#333;">
          <p style="margin:6px 0;">{{ item.core_summary }}</p>
          <p style="margin:6px 0;padding:8px 12px;background:#F4A26122;border-left:3px solid #F4A261;font-style:italic;">
            💡 {{ item.expert_insight }}
          </p>
          <div style="margin-top:8px;font-size:12px;color:#666;">
            {% for tag in item.tags %}<span style="background:#eee;padding:2px 6px;border-radius:4px;margin-right:4px;">#{{ tag }}</span>{% endfor %}
          </div>
          <a href="{{ item.source_url }}" style="display:inline-block;margin-top:8px;font-size:13px;color:#1A2B3C;">→ 原文連結</a>
        </div>
      </details>
      {% endfor %}
    {% else %}
      <p style="background:#fff;padding:14px;border-radius:10px;color:#888;font-size:14px;">
        {{ section.fallback_note }}
      </p>
    {% endif %}
  </div>
  {% endfor %}

  <!-- Footer -->
  <div style="margin-top:32px;padding:16px;text-align:center;font-size:12px;color:#888;">
    Daily AI Insights · Generated by Gemini 2.5 Pro<br>
    {% if pages_url %}<a href="{{ pages_url }}" style="color:#1A2B3C;">→ 線上閱讀完整歷史存檔</a>{% endif %}
  </div>

</div>
</body>
</html>
